# Copy to `.env` and fill in. `.env` is gitignored.
# Or export these variables in your shell before running make/uv commands.

# GCP project billed for BigQuery queries. Replace with your own project ID.
BIGQUERY_PROJECT_ID="your-gcp-project-id"

# Optional path to a service-account JSON file. If unset, Application Default
# Credentials are used: `gcloud auth application-default login`.
GOOGLE_APPLICATION_CREDENTIALS=""

# Refuse any single billed BigQuery query above this dry-run estimate.
BQ_MAX_SCAN_GIB="20"

# Local output roots; data/parquet and data/logs are gitignored/regenerable.
DATA_DIR="./data/parquet"
EXTRACTION_LOG_DIR="./data/logs"
